generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── UTILISATEURS & AUTH ─────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  OPERATOR
  VIEWER
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(VIEWER)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  assignedSites  UserSite[]
  movements      StockMovement[]
  acknowledgedAlerts Alert[] @relation("AcknowledgedBy")
  auditLogs      AuditLog[]

  @@map("users")
}

model UserSite {
  userId String @map("user_id")
  siteId String @map("site_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@id([userId, siteId])
  @@map("user_sites")
}

// ─── RÉFÉRENTIEL PRODUITS ────────────────────────────────

model Category {
  id         String     @id @default(uuid())
  parentId   String?    @map("parent_id")
  name       String
  depthLevel Int        @default(0) @map("depth_level")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  parent     Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children   Category[] @relation("CategoryTree")
  products   Product[]
  customFieldDefs CustomFieldDef[]

  @@map("categories")
}

model Product {
  id            String   @id @default(uuid())
  sku           String   @unique
  name          String
  categoryId    String?  @map("category_id")
  unitOfMeasure String   @default("unité") @map("unit_of_measure")
  barcode       String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  category         Category?                @relation(fields: [categoryId], references: [id])
  customFieldValues ProductCustomFieldValue[]
  stockLevels      StockLevel[]
  movements        StockMovement[]
  thresholds       StockThreshold[]
  suppliers        ProductSupplier[]

  @@map("products")
}

// ─── ATTRIBUTS DYNAMIQUES (EAV TYPÉ) ────────────────────

enum FieldType {
  TEXT
  NUMBER
  DATE
  SELECT
}

model CustomFieldDef {
  id                  String    @id @default(uuid())
  name                String
  fieldType           FieldType @map("field_type")
  isRequired          Boolean   @default(false) @map("is_required")
  appliesToCategoryId String?   @map("applies_to_category_id")
  createdAt           DateTime  @default(now()) @map("created_at")

  appliesToCategory Category?           @relation(fields: [appliesToCategoryId], references: [id])
  options           CustomFieldOption[]
  values            ProductCustomFieldValue[]

  @@map("custom_field_defs")
}

model CustomFieldOption {
  id         String @id @default(uuid())
  fieldDefId String @map("field_def_id")
  label      String
  sortOrder  Int    @default(0) @map("sort_order")

  fieldDef CustomFieldDef           @relation(fields: [fieldDefId], references: [id], onDelete: Cascade)
  values   ProductCustomFieldValue[]

  @@map("custom_field_options")
}

model ProductCustomFieldValue {
  id            String   @id @default(uuid())
  productId     String   @map("product_id")
  fieldDefId    String   @map("field_def_id")
  valueText     String?  @map("value_text")
  valueNumber   Float?   @map("value_number")
  valueDate     DateTime? @map("value_date")
  valueOptionId String?  @map("value_option_id")

  product   Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  fieldDef  CustomFieldDef    @relation(fields: [fieldDefId], references: [id], onDelete: Cascade)
  option    CustomFieldOption? @relation(fields: [valueOptionId], references: [id])

  @@unique([productId, fieldDefId])
  @@map("product_custom_field_values")
}

// ─── FOURNISSEURS ────────────────────────────────────────

model Supplier {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  contact   String?
  email     String?
  phone     String?
  address   String?
  nif       String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products  ProductSupplier[]
  movements StockMovement[]

  @@map("suppliers")
}

model ProductSupplier {
  productId  String @map("product_id")
  supplierId String @map("supplier_id")

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@id([productId, supplierId])
  @@map("product_suppliers")
}

// ─── HIÉRARCHIE DE STOCKAGE ──────────────────────────────

// ─── CLIENTS ─────────────────────────────────────────────

enum ClientType {
  COMPANY
  INDIVIDUAL
  GOVERNMENT
  OTHER
}

model Client {
  id          String     @id @default(uuid())
  code        String     @unique
  name        String
  type        ClientType @default(COMPANY)
  contact     String?
  email       String?
  phone       String?
  address     String?
  nif         String?    @map("tax_id")
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  movements   StockMovement[]

  @@map("clients")
}

// ─── HIÉRARCHIE DE STOCKAGE (suite) ─────────────────────

enum SiteType {
  WAREHOUSE
  STORE
  OTHER
}

enum ZoneType {
  AISLE
  SHELF
  AREA
  OTHER
}

model Site {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  type      SiteType @default(WAREHOUSE)
  address   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  zones      Zone[]
  thresholds StockThreshold[]
  users      UserSite[]

  @@map("sites")
}

model Zone {
  id       String   @id @default(uuid())
  siteId   String   @map("site_id")
  code     String
  name     String
  type     ZoneType @default(AISLE)
  isActive Boolean  @default(true) @map("is_active")

  site      Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  locations Location[]

  @@unique([siteId, code])
  @@map("zones")
}

model Location {
  id          String  @id @default(uuid())
  zoneId      String  @map("zone_id")
  code        String
  label       String?
  maxCapacity Int?    @map("max_capacity")
  isActive    Boolean @default(true) @map("is_active")

  zone        Zone          @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  stockLevels StockLevel[]
  movementsIn  StockMovement[] @relation("DestLocation")
  movementsOut StockMovement[] @relation("SourceLocation")

  @@unique([zoneId, code])
  @@map("locations")
}

// ─── STOCK & MOUVEMENTS ──────────────────────────────────

model StockLevel {
  id          String   @id @default(uuid())
  productId   String   @map("product_id")
  locationId  String   @map("location_id")
  quantity    Float    @default(0)
  reservedQty Float    @default(0) @map("reserved_qty")
  updatedAt   DateTime @updatedAt @map("updated_at")

  product  Product  @relation(fields: [productId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@unique([productId, locationId])
  @@map("stock_levels")
}

enum MovementType {
  IN
  OUT
  TRANSFER
  ADJUSTMENT
}

model StockMovement {
  id               String       @id @default(uuid())
  reference        String       @unique @default(uuid())
  type             MovementType
  productId        String       @map("product_id")
  sourceLocationId String?      @map("source_location_id")
  destLocationId   String?      @map("dest_location_id")
  quantity         Float
  reason           String?
  performedBy      String       @map("performed_by")
  batchId          String?      @map("batch_id")
  clientId         String?      @map("client_id")
  supplierId       String?      @map("supplier_id")
  createdAt        DateTime     @default(now()) @map("created_at")

  product        Product   @relation(fields: [productId], references: [id])
  sourceLocation Location? @relation("SourceLocation", fields: [sourceLocationId], references: [id])
  destLocation   Location? @relation("DestLocation", fields: [destLocationId], references: [id])
  performer      User      @relation(fields: [performedBy], references: [id])
  client         Client?   @relation(fields: [clientId], references: [id])
  supplier       Supplier? @relation(fields: [supplierId], references: [id])

  @@index([productId, createdAt])
  @@index([batchId])
  @@map("stock_movements")
}

// ─── SEUILS & ALERTES ────────────────────────────────────

model StockThreshold {
  id             String  @id @default(uuid())
  productId      String  @map("product_id")
  siteId         String? @map("site_id")
  minQuantity    Float   @map("min_quantity")
  safetyQuantity Float   @map("safety_quantity")
  maxQuantity    Float?  @map("max_quantity")
  reorderPoint   Float   @map("reorder_point")
  isActive       Boolean @default(true) @map("is_active")

  product Product @relation(fields: [productId], references: [id])
  site    Site?   @relation(fields: [siteId], references: [id])
  alerts  Alert[]

  @@unique([productId, siteId])
  @@map("stock_thresholds")
}

enum AlertStatus {
  TRIGGERED
  ACKNOWLEDGED
  RESOLVED
}

model Alert {
  id             String      @id @default(uuid())
  thresholdId    String      @map("threshold_id")
  currentQty     Float       @map("current_qty")
  status         AlertStatus @default(TRIGGERED)
  triggeredAt    DateTime    @default(now()) @map("triggered_at")
  acknowledgedBy String?     @map("acknowledged_by")
  resolvedAt     DateTime?   @map("resolved_at")

  threshold    StockThreshold @relation(fields: [thresholdId], references: [id])
  acknowledger User?          @relation("AcknowledgedBy", fields: [acknowledgedBy], references: [id])

  @@index([status])
  @@map("alerts")
}

// ─── AUDIT ───────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  payload    Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId, createdAt])
  @@map("audit_logs")
}
